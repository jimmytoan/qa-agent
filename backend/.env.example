# ─────────────────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/qa_agent

# ─────────────────────────────────────────────────────────────────────────────
# AI Provider — set only the keys for the provider(s) you want to use.
# The backend picks the provider automatically based on the model name:
#   gemini-*  → Google Gemini
#   claude-*  → Anthropic
#   anything else → Azure OpenAI (if AZURE_OPENAI_API_KEY is set) else OpenAI
# ─────────────────────────────────────────────────────────────────────────────

# OpenAI
OPENAI_API_KEY=sk-...

# Azure OpenAI (takes priority over OPENAI_API_KEY for GPT/o-series models)
AZURE_OPENAI_API_KEY=...
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5.4  # optional, defaults to the model name

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
GOOGLE_API_KEY=AIza...

# ─────────────────────────────────────────────────────────────────────────────
# Browser / agent settings
# ─────────────────────────────────────────────────────────────────────────────
BROWSER_HEADLESS=false        # set to true in CI / server environments
MAX_CONCURRENT_RUNS=30        # max browser sessions running in parallel
